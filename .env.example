# =============================================================================
# Suncoast Pool Pros — Environment variables
# =============================================================================
# Copy this file to `.env` for local dev. In production, set these in the
# Cloudflare Pages dashboard (Settings → Environment Variables).
#
# Two categories:
#   - VITE_*  → exposed to the browser bundle (anyone with DevTools can read them)
#   - others  → server-side only, used by the Pages Function at /api/contact
# =============================================================================


# ---- Client-side (browser) -------------------------------------------------

# Cloudflare Turnstile site key (the PUBLIC key — safe to expose).
# Create a site at: https://dash.cloudflare.com/?to=/:account/turnstile
# Leave blank during initial development; the Function accepts no-token
# submissions when TURNSTILE_SECRET_KEY is also blank.
VITE_TURNSTILE_SITE_KEY=


# ---- Server-side (Cloudflare Pages Function only) --------------------------
# These are read by `functions/api/contact.ts`. Never prefix with VITE_.

# Resend API key (https://resend.com). Starts with `re_`. Sending access only.
RESEND_API_KEY=

# Cloudflare Turnstile SECRET key (never expose). Pairs with VITE_TURNSTILE_SITE_KEY.
# When blank, the Function skips captcha verification (dev-friendly default).
TURNSTILE_SECRET_KEY=

# The address that receives form submissions.
CONTACT_TO_EMAIL=service@suncoastpoolpros.com

# The address that appears in the "From:" header. Must be on a verified Resend
# domain. Replies from leads go here too.
CONTACT_FROM_EMAIL=noreply@suncoastpoolpros.com

# (Optional) Comma-separated origin allow-list for the /api/contact endpoint.
# Leave blank to default to "same origin as the Function is served from",
# which covers normal production traffic. Set this if you ever need to allow
# a preview deploy URL or a partner subdomain to call the endpoint.
# Example: https://suncoastpoolpros.com,https://www.suncoastpoolpros.com
ALLOWED_ORIGINS=
