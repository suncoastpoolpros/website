# Signup webhook destinations. Copy this file to `.env` and fill in real URLs.
# Both must be VITE_-prefixed to be exposed to the browser bundle.
# The signup form POSTs the same JSON payload to every URL set here.

# Your contacts app / CRM webhook (adds the customer to your contacts)
VITE_CONTACTS_WEBHOOK_URL=

# QUO phone system webhook
VITE_QUO_WEBHOOK_URL=
