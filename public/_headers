# Security + cache headers for Cloudflare Pages.
# Reference: https://developers.cloudflare.com/pages/configuration/headers/

# All routes — base security headers.
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Long-cache hashed build assets — Vite filenames include a content hash.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts. Filenames (inter-400.woff2 etc.) are stable across
# deploys so we can immutable-cache them too. Previously these were defaulting
# to a 4-hour Cloudflare TTL — meaning return visitors re-downloaded all the
# fonts every half-day for no reason.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache fonts and images that don't change often.
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Prerendered HTML — browser always revalidates with Cloudflare (so a redeploy
# rolls out immediately to all visitors), but the edge keeps a cached copy and
# can answer a conditional GET with a 304 in single-digit ms. CF Pages does NOT
# honor stale-while-revalidate for background revalidation, so we don't bother
# setting it. Reference:
# https://developers.cloudflare.com/cache/concepts/cache-control/
/*.html
  Cache-Control: public, max-age=0, must-revalidate
